# Copy this to ".env" in the project root.

# PostgreSQL connection string.
DATABASE_URL=postgresql://cyberaudit:cyberaudit@localhost:5432/cyberaudit

# Port the API server listens on.
PORT=5000

# Public URL of the API server — embedded in the agent download bundle
# so Windows machines know where to POST their scan results.
# Change this to your machine's LAN IP or hostname when using on a network.
PUBLIC_URL=http://localhost:5000
