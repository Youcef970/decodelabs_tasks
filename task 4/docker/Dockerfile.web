FROM node:22-slim AS build

RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY package.json pnpm-workspace.yaml tsconfig.json tsconfig.base.json .npmrc ./
COPY lib ./lib
COPY artifacts/cyber-audit-pro ./artifacts/cyber-audit-pro

RUN pnpm install --ignore-scripts || true
RUN cd node_modules/esbuild && npm run build-package || true
RUN pnpm install

# BASE_PATH=/ because in Docker there is no Replit path prefix.
# PORT is required by vite.config.ts validation but unused at build time.
ENV BASE_PATH=/ PORT=3000
RUN pnpm --filter @workspace/cyber-audit-pro run build

FROM nginx:1.27-alpine

COPY --from=build /app/artifacts/cyber-audit-pro/dist/public /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
